{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/s/:id",
      "destination": "/api/share?id=:id"
    },
    {
      "source": "/qr/:id.svg",
      "destination": "/api/qrcode?id=:id"
    }
  ]
}
